# Environment Configuration
# Copy this file to .env and adjust values as needed.

# Server
HOST=127.0.0.1
PORT=8080
REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=30s

# TLS (optional)
TLS_CERT_PATH=./cert.pem
TLS_KEY_PATH=./key.pem

# Authentication
# Generate keys with: make generate-keys
AUTH_PUBLIC_PEM_FILEPATH=./public.pem
AUTH_PRIVATE_PEM_FILEPATH=./private.pem

# Encryption
ENCRYPTION_KEY_FILEPATH=./encryption.key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.nvisy.com
CORS_MAX_AGE=1h
CORS_ALLOW_CREDENTIALS=true

# OpenAPI
OPENAPI_JSON_PATH=/api/openapi.json
OPENAPI_SCALAR_PATH=/api/scalar

# PostgreSQL
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_CONNECTION_TIMEOUT=30s
POSTGRES_IDLE_TIMEOUT=10m

# NATS
NATS_URL=nats://localhost:4222
NATS_TOKEN=
NATS_CLIENT_NAME=nvisy-server
NATS_CONNECT_TIMEOUT=30s
NATS_REQUEST_TIMEOUT=30s
NATS_MAX_RECONNECTS=10

# Pipeline
PIPELINE_MAX_CONCURRENT_JOBS=10

# Logging
RUST_LOG=info,nvisy_cli=debug,nvisy_server=debug,nvisy_postgres=debug,nvisy_nats=debug,nvisy_webhook=debug
RUST_BACKTRACE=0
